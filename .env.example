# ========================================
# Twitter Multi-Account Bookmark App
# 環境変数設定テンプレート
# このファイルをコピーして .env を作成してください
# cp .env.example .env
# ========================================

# ----- Crawler -----

# クロールスケジュール (cron 式)
# デフォルト: 毎時 0 分
CRAWL_SCHEDULE=0 * * * *

# 起動時に即クロールを実行するか
# true / false
CRAWL_ON_STARTUP=true

# ----- Cookie 手動設定 (任意) -----
# ログインの代わりに Cookie を直接指定する場合に設定
# アカウント名（大文字）をサフィックスに付ける
# TWITTER_AUTH_TOKEN_MYUSER=xxxxxxxx
# TWITTER_CT0_MYUSER=xxxxxxxx

# ----- プロキシ設定 (任意) -----
# Twitter へのアクセスにプロキシを使用する場合に設定
# PROXY_SERVER=proxy.example.com:8080
# PROXY_USERNAME=user
# PROXY_PASSWORD=password

# ----- Analyzer 設定 (任意) -----
# analyzer サービスを有効にする場合に設定
# Docker Compose の analyzer プロファイルと合わせて使用する
# ANALYZER_URL=http://analyzer:3002
